# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Channel names (schimba daca le numesti altfel)
CHANNEL_FACEBOOK_IDS=facebook-ids
CHANNEL_INSTAGRAM_IDS=instagram-ids
CHANNEL_COMMANDS=comenzi

# Cohere
COHERE_API_KEY=your_cohere_api_key_here
COHERE_MODEL=command-r-plus

# Facebook credentials
FB_EMAIL=your_facebook_email@example.com
FB_PASSWORD=your_facebook_password

# Instagram credentials
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Browser (pune true daca nu vrei sa vezi browserul)
HEADLESS=false
BROWSER_TIMEOUT=30000

# Comportament
CONTEXT_MESSAGE_LIMIT=10
MIN_DELAY=1.5
MAX_DELAY=4.0
